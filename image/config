# pi-gen configuration for the little-internet node image.
#
# This file is copied into the pi-gen checkout by ./build.sh. See pi-gen's
# README for the full list of supported variables:
# https://github.com/RPi-Distro/pi-gen#config

IMG_NAME='little-internet'

# Raspberry Pi OS release to base the image on.
RELEASE='bookworm'

# Build a headless (Lite) image plus our custom networking stage. We stop after
# stage2 (Lite) — no desktop. build.sh adds SKIP_IMAGES to stage2 so only the
# final little-internet image is exported.
STAGE_LIST='stage0 stage1 stage2 stage-little-internet'

# Compress the exported image so it's smaller to move around / flash.
DEPLOY_COMPRESSION='xz'

# --- First-boot defaults -----------------------------------------------------
# All nodes ship with this same default hostname, so multiple cards collide on
# pi-node.local. Give each card a unique name by dropping a little-internet.txt
# on the boot partition; a first-boot service (stage-little-internet/
# 01-firstboot-config) reads it before mDNS advertises. See image/README.md →
# Quickstart, step 3. Don't rely on Raspberry Pi Imager's customization for this
# — it's unreliable for custom images.
TARGET_HOSTNAME='pi-node'

# Default login. CHANGE THIS for anything beyond a closed lab network — the
# password is baked into the image in plaintext.
FIRST_USER_NAME='pi'
FIRST_USER_PASS='little-internet'

# Keep the 'pi' user as a permanent account instead of pi-gen's default
# behavior of treating it as build-only and forcing a "create your real user"
# step on first boot. With the default (rename enabled), Raspberry Pi OS arms
# the userconf-pi first-boot flow and shows an SSH pre-login banner — "Please
# note that SSH may not work until a valid user has been set up" — until that
# flow completes, which never happens on our headless image. Setting this to 1
# disables the rename so 'pi' is stable and the banner goes away. Requires
# FIRST_USER_PASS to be set (above). Tradeoff: we intentionally ship a known
# default username/password — fine for a closed lab, not for exposed nodes.
DISABLE_FIRST_BOOT_USER_RENAME=1

# Enable SSH so nodes are reachable headless out of the box.
ENABLE_SSH=1

# Set the WLAN regulatory domain. This also unblocks the Wi-Fi radio (rfkill),
# which is required before any Wi-Fi will work — including a connection
# pre-provisioned via image/config.local (see config.local.example). Defaults to
# the author's region; override it in config.local if you build elsewhere (e.g.
# WPA_COUNTRY='GB'). Note this only applies to images you build yourself — a
# released image carries this value, but anyone flashing it sets their own
# country in the boot-partition file (see image/README.md → Customizing a
# flashed image).
WPA_COUNTRY='US'

# --- Locale ------------------------------------------------------------------
LOCALE_DEFAULT='en_US.UTF-8'
KEYBOARD_KEYMAP='us'
KEYBOARD_LAYOUT='English (US)'
TIMEZONE_DEFAULT='America/Phoenix'
