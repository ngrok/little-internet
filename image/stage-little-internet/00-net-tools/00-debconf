# Don't start iperf3 as a daemon at boot — lessons run `iperf3 -s` on demand.
# Preseeded so the build never stops on iperf3's interactive prompt.
iperf3 iperf3/start_daemon boolean false

# Let non-root users capture packets. This makes the wireshark-common install
# create the 'wireshark' group and grant /usr/bin/dumpcap the capture
# capabilities (cap_net_raw,cap_net_admin), owned root:wireshark and mode 0750.
# tshark (and Wireshark) capture through dumpcap, so members of that group can
# run `tshark` without sudo — see 03-run.sh, which adds the default user to it.
# Preseeded so the build never stops on the wireshark-common prompt.
wireshark-common wireshark-common/install-setuid boolean true
