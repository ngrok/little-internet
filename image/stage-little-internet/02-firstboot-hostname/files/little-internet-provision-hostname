#!/bin/bash
#
# Set the system hostname at boot from a file the user dropped onto the FAT boot
# partition. This is how a node flashed from a *released* image — where the
# flasher never ran the build, so the build-time hostname in config was never an
# option — gets a unique name headless, before mDNS advertises it.
#
# Every card flashed from the same image defaults to "pi-node", so without this
# they all collide on pi-node.local and avahi renames them unpredictably
# (pi-node-2.local, …). Give each card a name here and it comes up as
# <name>.local on first boot.
#
# Looks for /boot/firmware/little-internet-hostname.txt containing a single
# hostname, e.g.:
#
#     pi-a
#
# (A leading "HOSTNAME=" is tolerated, so "HOSTNAME=pi-a" works too.) Lines that
# are blank or start with '#' are ignored, so the shipped template's comments
# don't get in the way; the first real line wins.
#
# Unlike the Wi-Fi provisioner, this does NOT delete the file: a hostname isn't
# secret, the file doubles as a physical label for the card, and it's read every
# boot so it stays authoritative (edit it and reboot to rename). The work is
# idempotent — once the hostname matches, re-runs are no-ops.

set -eu

BOOT_HOSTNAME="/boot/firmware/little-internet-hostname.txt"
PLACEHOLDER="pi-CHANGEME"

log() { echo "little-internet-hostname: $*"; }

[ -f "$BOOT_HOSTNAME" ] || exit 0

NEW_HOSTNAME=""
while IFS= read -r line || [ -n "$line" ]; do
	# Strip a trailing CR so files edited on Windows still parse.
	line="${line%$'\r'}"
	case "$line" in
		\#*|"") continue ;;
	esac
	# Tolerate a "HOSTNAME=" prefix and surrounding quotes; a hostname has no
	# internal whitespace, so trimming all of it is safe.
	line="${line#HOSTNAME=}"
	line="${line%\"}"; line="${line#\"}"
	line="$(echo "$line" | tr -d '[:space:]')"
	[ -n "$line" ] || continue
	NEW_HOSTNAME="$line"
	break
done < "$BOOT_HOSTNAME"

# File was all comments/blank — treat as "no hostname wanted", not an error, and
# leave the image on its default name.
if [ -z "$NEW_HOSTNAME" ]; then
	exit 0
fi

# The user copied the template but never edited it. Don't name every card
# "pi-CHANGEME"; tell them what to fix and leave the default hostname in place.
if [ "$NEW_HOSTNAME" = "$PLACEHOLDER" ]; then
	log "file still has the example placeholder — set a name in $BOOT_HOSTNAME, then reboot. Leaving the hostname unchanged."
	exit 0
fi

# Validate as a single RFC-1123 DNS label: 1–63 chars, letters/digits/hyphens
# only, no leading or trailing hyphen (and so no dots, spaces, or underscores).
if ! echo "$NEW_HOSTNAME" | grep -Eq '^[A-Za-z0-9]([A-Za-z0-9-]{0,61}[A-Za-z0-9])?$'; then
	log "ERROR: '$NEW_HOSTNAME' in $BOOT_HOSTNAME is not a valid hostname. Use 1–63 characters: letters, digits, and hyphens only; no leading/trailing hyphen, dots, spaces, or underscores (e.g. pi-a). Hostname NOT changed. Fix it and reboot."
	exit 1
fi

CURRENT_HOSTNAME="$(cat /etc/hostname 2>/dev/null | tr -d '[:space:]' || true)"

# Idempotent: if it's already set, make sure the running kernel hostname agrees
# (cheap) and stop — don't rewrite files every boot.
if [ "$CURRENT_HOSTNAME" = "$NEW_HOSTNAME" ]; then
	[ "$(hostname)" = "$NEW_HOSTNAME" ] || hostname "$NEW_HOSTNAME" || true
	log "hostname already '$NEW_HOSTNAME'; nothing to do"
	exit 0
fi

# Persist for future boots.
echo "$NEW_HOSTNAME" > /etc/hostname

# Update the 127.0.1.1 line in /etc/hosts so local name lookups resolve to the
# new name (Debian/RPi OS convention). Rewrite the line if present; add it if
# this image somehow shipped without one.
if grep -qE '^127\.0\.1\.1[[:space:]]' /etc/hosts; then
	sed -i -E "s/^127\.0\.1\.1[[:space:]].*/127.0.1.1\t$NEW_HOSTNAME/" /etc/hosts
else
	printf '127.0.1.1\t%s\n' "$NEW_HOSTNAME" >> /etc/hosts
fi

# Set the running hostname now, before avahi-daemon advertises it, so this boot
# already comes up as <name>.local. hostnamectl keeps systemd in sync if its
# dbus service is up yet; the plain hostname(1) call is the reliable fallback.
hostname "$NEW_HOSTNAME"
hostnamectl set-hostname "$NEW_HOSTNAME" 2>/dev/null || true

log "hostname set to '$NEW_HOSTNAME'"
