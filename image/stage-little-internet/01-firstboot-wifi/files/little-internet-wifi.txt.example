# little-internet — join this Pi to your Wi-Fi
#
# To have this node connect to your Wi-Fi headless on first boot:
#   1. Copy this file to "little-internet-wifi.txt" in this same folder
#      (just drop the .example from the name).
#   2. Set all three values below: network name, password, and your country.
#   3. Eject the card and boot the Pi.
#
# On first boot the Pi reads the file, connects to Wi-Fi, and then DELETES it
# so your password doesn't sit in plaintext on the card. To switch networks
# later, drop a fresh little-internet-wifi.txt here and reboot.
#
# Assumes a normal WPA/WPA2 password-protected network. If you leave this as
# .example (or don't create the file), the Pi just boots without Wi-Fi — bring
# it up over Ethernet instead (SSH is enabled).

# Your network name.
SSID=YourNetwork

# Your network password.
PSK=YourPassword

# Two-letter ISO country code for where this Pi runs (e.g. US, GB, DE, FR, JP,
# AU). REQUIRED: it sets the WLAN regulatory domain and unblocks the radio, and
# the correct value is region-specific — the image can't guess it for you.
COUNTRY=US
